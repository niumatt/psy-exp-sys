.container {
  min-height: 100vh;
  background-color: #f6f6f6;
  padding-bottom: 48rpx;
}

.loading-tip {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.reward-highlight {
  color: #e34d59 !important;
  font-weight: bold;
}

.apply-area {
  padding: 48rpx 32rpx 0;
}

/* Popup */
.popup-block {
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

.popup-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.popup-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
}

.popup-btn {
  font-size: 28rpx;
  padding: 8rpx 16rpx;
}

.popup-btn--cancel {
  color: #999;
}

.popup-btn--confirm {
  color: #0052d9;
  font-weight: bold;
}

.popup-body {
  max-height: 60vh;
  padding: 24rpx 32rpx;
}

.popup-body--tree {
  height: 50vh;
  padding: 0;
  display: flex;
  flex-direction: row;
}

.tree-left {
  width: 220rpx;
  background-color: #f6f6f6;
  height: 100%;
  overflow-y: auto;
}

.tree-date-item {
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  color: #666;
  border-bottom: 1rpx solid #ebebeb;
}

.tree-date-item--active {
  background-color: #fff;
  color: #0052d9;
  font-weight: bold;
  border-left: 6rpx solid #0052d9;
}

.tree-right {
  flex: 1;
  height: 100%;
}

.tree-slot-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  font-size: 28rpx;
  color: #1a1a1a;
  border-bottom: 1rpx solid #f5f5f5;
}

.tree-slot-item--disabled {
  color: #bbb;
}

.tree-slot-item--selected {
  color: #0052d9;
}

.criteria-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.criteria-row:last-child {
  border-bottom: none;
}
