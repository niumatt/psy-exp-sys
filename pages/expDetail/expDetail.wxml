<view class="detail-container">
  <view wx:if="{{!exp}}" class="loading-tip">加载中...</view>
  <view wx:if="{{exp}}" class="header-section">
    <view class="main-title">{{exp.title}}</view>
    <view class="tag-row">
      <t-tag theme="success" variant="light" size="small">{{exp.status}}</t-tag>
      <t-tag 
        wx:for="{{exp.tags}}" 
        wx:key="index" 
        theme="primary" 
        variant="light" 
        size="medium"
      >{{item}}</t-tag>
    </view>
  </view>

  <block wx:if="{{exp}}">
    <t-cell-group theme="card">
      <t-cell 
        title="实验报酬" 
        note="{{exp.reward}}" 
        t-class-note="reward-highlight" 
        left-icon="thumb-up"
      />
      <t-cell 
        title="预计时长" 
        note="{{exp.expDurationMinutes}} 分钟" 
        left-icon="time" 
      />
      <t-cell 
        title="主试人员" 
        note="{{exp.researcherName}}" 
        left-icon="user" 
      />
      <t-cell 
        title="当前报名" 
        note="{{exp.participantCount}} / 50" 
        left-icon="chart-bar" 
      />
    </t-cell-group>

    <t-divider />

    <t-collapse theme="card" expandIcon>
      <t-collapse-panel header="实验简介" value="{{0}}">
        <view class="collapse-content">{{exp.description || '暂无简介'}}</view>
      </t-collapse-panel>
      <t-collapse-panel header="招募要求" value="{{1}}">
        <view class="collapse-content">
          <view
            wx:for="{{exp.criteria}}"
            wx:key="index"
            class="criteria-item"
          >{{item}}</view>
        </view>
      </t-collapse-panel>
      <t-collapse-panel header="实验地点" value="{{2}}">
        <view class="collapse-content">{{exp.location || '暂无地点信息'}}</view>
      </t-collapse-panel>
      <t-collapse-panel header="实验时间" value="{{3}}">
        <view wx:if="{{slotsTree.length === 0}}" class="collapse-content">暂无可用时间段</view>
        <view wx:else class="slots-tree">
          <view
            wx:for="{{slotsTree}}"
            wx:key="value"
            class="slot-date-group"
          >
            <view class="slot-date-label">{{item.label}}</view>
            <view
              wx:for="{{item.children}}"
              wx:for-item="slot"
              wx:key="value"
              class="slot-time-item {{slot.disabled ? 'slot-disabled' : ''}}"
            >{{slot.label}}</view>
          </view>
        </view>
      </t-collapse-panel>
    </t-collapse>

    <t-divider />

    <view class="apply-area">
      <t-button
        theme="primary"
        size="medium"
        block="{{false}}"
        t-class="apply-btn"
        content="立即报名"
        bind:tap="handleApply"
      />
    </view>
  </block>
</view>